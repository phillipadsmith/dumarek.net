---
const FORMSPREE_ENDPOINT = 'https://formspree.io/f/xaqgpgzr';
// TODO: confirm the contact email address.
const EMAIL = 'hello@dumarek.net';

// TODO: adjust these dropdown options — placeholders pending Phillip's real lists.
const describesYou = [
  'Artist / band',
  'Songwriter',
  'Manager or label',
  'Other',
];
const helpWith = [
  'Full production',
  'Songwriting',
  'Vocal tracking',
  'Mixing',
  'Not sure yet',
];
const budgets = [
  'Under $1,000',
  '$1,000 – $3,000',
  '$3,000 – $5,000',
  '$5,000+',
  'Prefer to discuss',
];
---

<section class="section" id="demo">
  <div class="wrap">
    <span class="eyebrow">Send your demo</span>
    <h2 class="section-title">
      Let's make <span class="gradient-text">music.</span>
    </h2>
    <p class="intro">
      Submit your inquiry and I'll be in touch within 24 hours.
    </p>
    <form action={FORMSPREE_ENDPOINT} method="POST">
      <input
        type="hidden"
        name="_subject"
        value="New inquiry from dumarek.net"
      />
      <div class="row">
        <label>
          Your full name
          <input type="text" name="full_name" required autocomplete="name" />
        </label>
        <label>
          Your email
          <input type="email" name="email" required autocomplete="email" />
        </label>
      </div>
      <div class="row">
        <label>
          Where are you located?
          <input
            type="text"
            name="location"
            required
            autocomplete="address-level2"
          />
        </label>
        <label>
          What best describes you?
          <select name="describes_you" required>
            {describesYou.map((o) => <option>{o}</option>)}
          </select>
        </label>
      </div>
      <label>
        Where can I hear your music?
        <input type="url" name="music_link" placeholder="https://…" required />
      </label>
      <label>
        What are you hoping to accomplish with your song/project?
        <textarea name="goals" rows="3" required></textarea>
      </label>
      <div class="row">
        <label>
          What can I help you with?
          <select name="help_with" required>
            {helpWith.map((o) => <option>{o}</option>)}
          </select>
        </label>
        <label>
          What funds have you allocated to this project?
          <select name="budget" required>
            {budgets.map((o) => <option>{o}</option>)}
          </select>
        </label>
      </div>
      <label>
        Describe your project in detail
        <textarea name="project_details" rows="5" required></textarea>
      </label>
      <label>
        How did you hear about my work?
        <input type="text" name="referral_source" required />
      </label>
      <button class="btn" type="submit">Send it over</button>
    </form>
    <p class="fallback">
      Forms not your thing? Email me directly at
      <a href={`mailto:${EMAIL}?subject=Inquiry%20for%20Dumarek`}>{EMAIL}</a>.
    </p>
  </div>
</section>

<style>
  .intro {
    color: var(--haze);
    font-size: var(--step-1);
    margin-bottom: 2.5rem;
  }

  form {
    max-width: 40rem;
    display: grid;
    gap: 1.25rem;
  }

  .row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  label {
    display: grid;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--haze);
    align-content: start;
  }

  input,
  select,
  textarea {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--cream);
    background: var(--vinyl-lift);
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 0.75rem 0.9rem;
  }

  input:focus,
  select:focus,
  textarea:focus {
    outline: 2px solid var(--gold);
    outline-offset: 0;
    border-color: transparent;
  }

  textarea {
    resize: vertical;
  }

  button.btn {
    justify-self: start;
    margin-top: 0.5rem;
  }

  .fallback {
    margin-top: 2rem;
    color: var(--haze);
    font-size: 0.9rem;
  }

  @media (max-width: 36rem) {
    .row {
      grid-template-columns: 1fr;
    }
  }
</style>
