---
// TODO: replace placeholder tracks with real titles, artists, roles, and links.
const tracks = [
  {
    n: '01',
    title: 'Track title',
    artist: 'Artist name',
    role: 'Production · Mix',
    href: '#',
  },
  {
    n: '02',
    title: 'Track title',
    artist: 'Artist name',
    role: 'Songwriting · Production',
    href: '#',
  },
  {
    n: '03',
    title: 'Track title',
    artist: 'Artist name',
    role: 'Production · Vocals · Mix',
    href: '#',
  },
];
---

<section class="section" id="work">
  <div class="wrap">
    <span class="eyebrow">Track sheet</span>
    <h2 class="section-title">Recent work</h2>
    <ol class="tracks">
      {
        tracks.map((t) => (
          <li>
            <a class="track" href={t.href}>
              <span class="trk">TRK {t.n}</span>
              <span class="title">{t.title}</span>
              <span class="artist">{t.artist}</span>
              <span class="role">{t.role}</span>
              <span class="listen" aria-hidden="true">
                Listen ↗
              </span>
            </a>
          </li>
        ))
      }
    </ol>
    <p class="more">
      More on my <a href="https://lnk.bio/dumarek">lnk.bio</a> while this list
      grows.
    </p>
  </div>
</section>

<style>
  .tracks {
    list-style: none;
    margin: 2rem 0 0;
    padding: 0;
    border-top: 1px solid var(--line);
  }

  .track {
    display: grid;
    grid-template-columns: 5.5rem 1.4fr 1fr 1.2fr auto;
    align-items: baseline;
    gap: 1rem;
    padding: 1.25rem 0.25rem;
    border-bottom: 1px solid var(--line);
    text-decoration: none;
    color: var(--cream);
    transition: background 150ms ease;
  }

  .track:hover {
    background: var(--vinyl-lift);
    color: var(--cream);
  }

  .trk {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    color: var(--tangerine);
  }

  .title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--step-1);
  }

  .artist {
    color: var(--haze);
  }

  .role {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--haze);
  }

  .listen {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--gold);
    opacity: 0;
    transition: opacity 150ms ease;
  }

  .track:hover .listen {
    opacity: 1;
  }

  .more {
    margin-top: 1.5rem;
    color: var(--haze);
    font-size: 0.9rem;
  }

  @media (max-width: 44rem) {
    .track {
      grid-template-columns: auto 1fr;
      grid-template-areas:
        'trk listen'
        'title title'
        'artist artist'
        'role role';
      row-gap: 0.25rem;
    }

    .trk {
      grid-area: trk;
    }
    .title {
      grid-area: title;
    }
    .artist {
      grid-area: artist;
    }
    .role {
      grid-area: role;
    }
    .listen {
      grid-area: listen;
      justify-self: end;
      opacity: 1;
    }
  }
</style>
