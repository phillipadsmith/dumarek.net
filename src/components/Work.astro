---
// TODO: paste the Disco.ac share link for the playlist to embed
// (in Disco: playlist → Share → copy link, e.g. https://s.disco.ac/xxxxxxxxxxxx).
// The placeholder box renders until this is set.
const DISCO_EMBED_URL = '';
---

<section class="section" id="work">
  <div class="wrap">
    <span class="eyebrow">Track sheet</span>
    <h2 class="section-title">Recent work</h2>
    {
      DISCO_EMBED_URL ? (
        <div class="player">
          <iframe
            src={DISCO_EMBED_URL}
            title="Dumarek — recent productions on Disco"
            loading="lazy"
            allow="autoplay"
          />
        </div>
      ) : (
        <div class="player placeholder" aria-label="Music player coming soon">
          <span>
            Player coming soon —<br />
            hear tracks on <a href="https://lnk.bio/dumarek">lnk.bio</a>
          </span>
        </div>
      )
    }
  </div>
</section>

<style>
  .player {
    margin-top: 2rem;
    border: 1px solid var(--line);
    border-radius: 4px;
    overflow: hidden;
  }

  .player iframe {
    display: block;
    width: 100%;
    height: 27rem;
    border: 0;
    background: var(--vinyl-lift);
  }

  .placeholder {
    height: 16rem;
    display: grid;
    place-items: center;
    text-align: center;
    border-style: dashed;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--haze);
    background:
      linear-gradient(160deg, rgba(232, 184, 75, 0.05), rgba(217, 74, 140, 0.05)),
      var(--vinyl-lift);
  }
</style>
