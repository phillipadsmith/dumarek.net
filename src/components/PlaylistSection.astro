---
interface Props {
  id: string;
  eyebrow: string;
  title: string;
  embedSrc: string;
  embedTitle: string;
}

const { id, eyebrow, title, embedSrc, embedTitle } = Astro.props;
---

<section class="section" id={id}>
  <div class="wrap">
    <span class="eyebrow">{eyebrow}</span>
    <h2 class="section-title">{title}</h2>
    <div class="player">
      <iframe
        src={embedSrc}
        title={embedTitle}
        loading="lazy"
        allowfullscreen
      />
    </div>
  </div>
</section>

<style>
  .player {
    margin-top: 2rem;
    border: 1px solid var(--line);
    border-radius: 4px;
    overflow: hidden;
  }

  .player iframe {
    display: block;
    width: 100%;
    height: 395px;
    border: 0;
    background: var(--vinyl-lift);
  }
</style>
